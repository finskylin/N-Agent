{
  "name": "通用Agent能力评测集 v1",
  "version": "1.0",
  "description": "评测Agent的工具调用能力和回答质量，覆盖数据查询、综合分析、研究报告三类场景",
  "questions": [
    {
      "id": "q001",
      "category": "数据查询",
      "difficulty": "easy",
      "question": "帮我查一下贵州茅台（600519）最新的股价和基本面信息",
      "expected_tools": ["stock_resolver", "financial_report"],
      "required_tools": ["financial_report"],
      "judge_focus": [
        "是否给出了贵州茅台的具体股价数字",
        "基本面信息是否包含营收、净利润等关键财务指标",
        "数据是否有明确来源"
      ],
      "hallucination_check": {
        "enabled": true,
        "numeric_fields": ["股价", "营收", "净利润", "市值"]
      }
    },
    {
      "id": "q002",
      "category": "数据查询",
      "difficulty": "easy",
      "question": "查一下招商银行（600036）的财务报表核心指标，包括ROE、净利润增速和不良贷款率",
      "expected_tools": ["stock_resolver", "financial_report"],
      "required_tools": ["financial_report"],
      "judge_focus": [
        "ROE数值是否具体",
        "净利润增速是否有数字",
        "不良贷款率是否提及",
        "财务数据是否有明确来源"
      ],
      "hallucination_check": {
        "enabled": true,
        "numeric_fields": ["ROE", "净利润增速", "不良贷款率"]
      }
    },
    {
      "id": "q003",
      "category": "数据查询",
      "difficulty": "easy",
      "question": "查看比亚迪（002594）的技术面信号，包括MACD、RSI和均线情况",
      "expected_tools": ["stock_resolver", "technical_indicators"],
      "required_tools": ["technical_indicators"],
      "judge_focus": [
        "是否给出MACD的具体数值或信号",
        "RSI数值是否明确",
        "均线情况是否描述清楚",
        "技术信号综合结论是否有依据"
      ],
      "hallucination_check": {
        "enabled": true,
        "numeric_fields": ["MACD", "RSI", "均线"]
      }
    },
    {
      "id": "q004",
      "category": "数据查询",
      "difficulty": "easy",
      "question": "查一下中芯国际（688981）的资金流向情况，近期主力资金是流入还是流出？",
      "expected_tools": ["stock_resolver", "fund_flow"],
      "required_tools": ["fund_flow"],
      "judge_focus": [
        "是否给出了具体的资金流入/流出金额",
        "主力资金方向是否明确",
        "是否有时间维度的说明（近几日）"
      ],
      "hallucination_check": {
        "enabled": true,
        "numeric_fields": ["资金流入", "资金流出", "净流入", "净流出"]
      }
    },
    {
      "id": "q005",
      "category": "数据查询",
      "difficulty": "easy",
      "question": "帮我看看宁德时代（300750）的估值情况，PE和PB分别是多少，是否处于历史高位？",
      "expected_tools": ["stock_resolver", "valuation_analysis"],
      "required_tools": ["valuation_analysis"],
      "judge_focus": [
        "PE数值是否具体",
        "PB数值是否具体",
        "是否与历史分位或行业均值对比",
